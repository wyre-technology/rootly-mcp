{
  "name": "@wyre-technology/rootly-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Rootly incident management platform",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "rootly-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "prebuild": "npm run clean",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "mcpb:pack": "npm run build && npm install --production && mcpb pack",
    "cf:deploy": "npm run build && wrangler deploy",
    "cf:dev": "npm run build && wrangler dev"
  },
  "keywords": [
    "rootly",
    "mcp",
    "incidents",
    "alerts",
    "on-call",
    "model-context-protocol",
    "msp",
    "wyre-technology"
  ],
  "author": "WYRE Technology",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wyre-technology/rootly-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "msw": "^2.4.0",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
